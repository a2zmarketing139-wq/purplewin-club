generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  phone         String    @unique
  password      String
  name          String
  referralCode  String    @unique @map("referral_code")
  referredBy    String?   @map("referred_by")
  referrer      User?     @relation("Referrals", fields: [referredBy], references: [id])
  referrals     User[]    @relation("Referrals")
  balance       Float     @default(0)
  totalDeposit  Float     @default(0) @map("total_deposit")
  totalWithdraw Float     @default(0) @map("total_withdraw")
  vipLevel      Int       @default(1) @map("vip_level")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  transactions  Transaction[]
  bets          Bet[]
  depositRequests   DepositRequest[]
  withdrawalRequests WithdrawalRequest[]

  notifications     Notification[]
  dailyBonuses      DailyBonus[]
  chatMessages      ChatMessage[]
  aviatorBets       AviatorBet[]
  chickenSessions   ChickenSession[]
  @@map("users")
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  type        String   // deposit, withdrawal, bet_place, bet_win, referral_bonus, bonus
  amount      Float
  balanceBefore Float @map("balance_before")
  balanceAfter  Float @map("balance_after")
  description String?
  referenceId String?  @map("reference_id")
  status      String   @default("completed") // pending, completed, failed, cancelled
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model Bet {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  gameType    String   @map("game_type") // wingo, slot, mines, plinko, dice
  gamePeriod  String?  @map("game_period")
  betAmount   Float    @map("bet_amount")
  betChoice   String?  @map("bet_choice") // number, color, etc.
  result      String?
  winAmount   Float    @default(0) @map("win_amount")
  multiplier  Float    @default(0)
  isWin       Boolean  @default(false) @map("is_win")
  status      String   @default("pending") // pending, won, lost, cancelled
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([gameType])
  @@index([createdAt])
  @@map("bets")
}

model DepositRequest {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  amount        Float
  method        String   // easypaisa, jazzcash, bank_transfer
  accountNumber String?  @map("account_number")
  accountName   String?  @map("account_name")
  screenshot    String?  // file path or URL
  status        String   @default("pending") // pending, approved, rejected
  adminNote     String?  @map("admin_note")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("deposit_requests")
}

model WithdrawalRequest {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  amount        Float
  method        String   // easypaisa, jazzcash, bank_transfer
  accountNumber String   @map("account_number")
  accountName   String   @map("account_name")
  status        String   @default("pending") // pending, approved, rejected, processed
  adminNote     String?  @map("admin_note")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("withdrawal_requests")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // deposit_approved, withdrawal_done, win_big, vip_upgrade, system
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model DailyBonus {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  loginDate   DateTime @map("login_date")
  streakDay   Int      @map("streak_day") // 1-7
  bonusAmount Float    @map("bonus_amount")
  claimed     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, loginDate])
  @@index([userId])
  @@map("daily_bonuses")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isAdmin   Boolean  @default(false) @map("is_admin")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isAdmin])
  @@map("chat_messages")
}

model AviatorRound {
  id                String   @id @default(cuid())
  crashMultiplier   Float    @map("crash_multiplier")
  status            String   @default("waiting") // waiting, flying, crashed
  createdAt         DateTime @default(now()) @map("created_at")
  endedAt           DateTime? @map("ended_at")

  bets              AviatorBet[]

  @@index([createdAt])
  @@index([status])
  @@map("aviator_rounds")
}

model AviatorBet {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  roundId             String   @map("round_id")
  round               AviatorRound @relation(fields: [roundId], references: [id])
  betAmount           Float    @map("bet_amount")
  cashoutMultiplier   Float?   @map("cashout_multiplier")
  winAmount           Float    @default(0) @map("win_amount")
  autoCashout         Float?   @map("auto_cashout")
  status              String   @default("active") // active, cashed_out, crashed
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([roundId])
  @@index([status])
  @@map("aviator_bets")
}

model ChickenSession {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  user               User     @relation(fields: [userId], references: [id])
  betAmount          Float    @map("bet_amount")
  difficulty         String   // easy, medium, hard, hardcore
  stepsCompleted     Int      @default(0) @map("steps_completed")
  totalSteps         Int      @map("total_steps")
  currentMultiplier  Float    @default(1.0) @map("current_multiplier")
  cashoutMultiplier  Float?   @map("cashout_multiplier")
  finalMultiplier    Float?   @map("final_multiplier")
  status             String   @default("playing") // playing, cashed_out, crashed
  winAmount          Float    @default(0) @map("win_amount")
  firePositions      String   @map("fire_positions") // JSON array of fire step indices
  createdAt          DateTime @default(now()) @map("created_at")
  endedAt            DateTime? @map("ended_at")

  @@index([userId])
  @@index([status])
  @@map("chicken_sessions")
}

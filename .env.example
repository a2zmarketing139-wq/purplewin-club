# PurpleWin Club - Environment Variables for Railway
# Copy this to .env and fill in values

# Database URL (Railway auto-provides this when you add PostgreSQL)
# For Railway: use the DATABASE_URL from your PostgreSQL service
# For local: use file:./dev.db for SQLite
DATABASE_URL="postgresql://user:password@host:5432/purplewin"

# JWT Secret (change this to a random string)
JWT_SECRET="your-super-secret-key-change-this"

# Admin credentials
ADMIN_PHONE="03052884177"
ADMIN_PASSWORD="@ ZainabAbbas732"

# Server port (Railway sets this automatically)
PORT=3000

# Node environment
NODE_ENV=production
